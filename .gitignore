# ── Runtime — generated by make build (never commit) ─────────────────────────
.env
synapse/homeserver.yaml
element/config.json
element/config.dev.json
cinny/config.json
coturn/turnserver.conf
livekit/livekit.yaml
bridges/telegram/config.yaml
bridges/whatsapp/config.yaml
bridges/discord/config.yaml
bridges/signal/config.yaml
traefik/traefik.yml
mas/config.yaml
garage/garage.toml
docker-compose.storage.yml

# ── Secrets & user config — contains passwords (never commit) ─────────────────
# .env.override is intentionally NOT ignored — it's the template users fill in.
# If you fork this repo privately, you may want to add it here.

# ── Synapse runtime files ─────────────────────────────────────────────────────
synapse/signing.key
synapse/*.log
synapse/*.pid

# ── Bridge registration files (generated on first bridge startup) ─────────────
bridges/*/registration.yaml

# ── TLS certificates ──────────────────────────────────────────────────────────
*.pem
*.crt
*.key

# ── Backups ───────────────────────────────────────────────────────────────────
backups/

# ── Editor & OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
