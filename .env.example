# ─────────────────────────────────────────────────────────────────────────────
#  HyperChat — main configuration file
#
#  1. Fill in the values below
#  2. Run: make secrets    — auto-generate all passwords & keys
#  3. Run: make check      — validate this file
#  4. Run: make build      — apply everything to all config files
#  5. Run: make start      — pull images and launch the stack
# ─────────────────────────────────────────────────────────────────────────────

# ── Deploy mode ───────────────────────────────────────────────────────────────
#
#   1 = local          No reverse proxy. Ports bound to 127.0.0.1.
#                      For testing on your own machine.
#
#   2 = local-traefik  Traefik as reverse proxy, HTTP only, no SSL.
#                      Useful for LAN setups or behind your own SSL terminator.
#
#   3 = server         Your own nginx/Caddy on the host handles SSL.
#                      Services bound to 127.0.0.1 — proxy connects via localhost.
#
#   4 = server-traefik Traefik inside Docker handles SSL via Let's Encrypt.
#                      Best choice when there is no existing web server.
#
DEPLOY_MODE=1

# ── Server identity ───────────────────────────────────────────────────────────

# Short name used as the Matrix server label and app name
SERVER_NAME=hyperchat

# Your domain — do NOT include https:// or trailing slashes
# For modes 1/2 you can leave this as localhost
DOMAIN=localhost

# Email for Let's Encrypt certificate registration (mode 4 only)
LETSENCRYPT_EMAIL=

# ── Subdomains ────────────────────────────────────────────────────────────────
#
# Subdomain prefix for each service. make build computes the full hostname as:
#   <SUBDOMAIN>.<DOMAIN>   — if SUBDOMAIN is set
#   <DOMAIN>               — if SUBDOMAIN is empty (root domain)
#
# Examples with DOMAIN=hyperchat.ru:
#   SUBDOMAIN_MATRIX=matrix     → matrix.hyperchat.ru   (Matrix API, default)
#   SUBDOMAIN_ELEMENT=          → hyperchat.ru           (root domain, recommended for main client)
#   SUBDOMAIN_ELEMENT=chat      → chat.hyperchat.ru
#
SUBDOMAIN_MATRIX=matrix
SUBDOMAIN_ELEMENT=
SUBDOMAIN_CINNY=cinny
SUBDOMAIN_LIVEKIT=livekit
SUBDOMAIN_STICKERS=stickers
SUBDOMAIN_MAS=auth

# ── Services — enable/disable ─────────────────────────────────────────────────

ENABLE_ELEMENT=true
ENABLE_CINNY=false

ENABLE_BRIDGE_TELEGRAM=false
ENABLE_BRIDGE_WHATSAPP=false
ENABLE_BRIDGE_DISCORD=false
ENABLE_BRIDGE_SIGNAL=false

ENABLE_VOIP=false
ENABLE_STICKERS=false

# Matrix Authentication Service — enables QR code login, OIDC/OAuth2, Element X support
# Requires its own subdomain (SUBDOMAIN_MAS) and runs as a separate container.
# After enabling, run: make build && make start
# First-time setup: MAS will auto-migrate its database on startup.
ENABLE_MAS=false

# Admin panel: synapse (default) or element
# When ENABLE_MAS=true, Element Admin is used automatically (Synapse Admin is incompatible with MAS auth).
# Element Admin: https://admin-beta.element.dev — connect to https://auth.<your-domain>/
# Synapse Admin: http://localhost:8082 (SSH tunnel required)
ADMIN_PANEL=synapse

# Allow new users to register accounts.
# When ENABLE_MAS=false: controls Synapse registration directly.
# When ENABLE_MAS=true:  controls registration via MAS (OIDC/password sign-up page).
ENABLE_REGISTRATION=false

# Expose Synapse Prometheus metrics on port 9000 (localhost only).
# Point your external Prometheus at localhost:9000 — run: make monitoring
ENABLE_MONITORING=false

# ── Ports (modes 1 and 3 only) ────────────────────────────────────────────────
# In modes 2/4 Traefik handles routing — these values are ignored.
# Synapse Admin is always on 127.0.0.1 regardless of mode.

PORT_SYNAPSE=8008
PORT_ELEMENT=8080
PORT_CINNY=8081
PORT_ADMIN=8082
PORT_LIVEKIT=7880
PORT_STICKERS=8090
PORT_MAS=8083

# ── Telegram bridge ───────────────────────────────────────────────────────────
# Obtain from https://my.telegram.org → API development tools

TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Discord bridge ────────────────────────────────────────────────────────────
# Create bot at https://discord.com/developers/applications
# Required intents: Server Members, Message Content

DISCORD_BOT_TOKEN=

# ── Storage ───────────────────────────────────────────────────────────────────
#
#   volumes  Docker named volumes (default, managed by Docker)
#   local    Bind-mount to a directory on the host (set DATA_PATH below)
#   garage   Local Garage container as S3 storage (auto-configured, lightweight)
#   s3       External S3-compatible storage (AWS, R2, B2, Garage remote, etc.)
#
STORAGE_TYPE=volumes

# Absolute path on the server when STORAGE_TYPE=local
# Example: /srv/hyperchat/data  or  /home/user/hyperchat-data
DATA_PATH=

# S3 settings when STORAGE_TYPE=s3
# Works with AWS S3, Cloudflare R2, MinIO, Backblaze B2, etc.
S3_BUCKET=hyperchat-media
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=garage

# Garage internal cluster secret — auto-generated by make secrets
GARAGE_RPC_SECRET=

ENABLE_EMAIL=false

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Configure interactively with: make email
# Leave SMTP_HOST empty to disable email entirely.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─────────────────────────────────────────────────────────────────────────────
#  Secrets — generated automatically by: make secrets
#  Do not edit these by hand unless you know what you are doing.
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_PASSWORD=
MACAROON_SECRET_KEY=
FORM_SECRET=
REGISTRATION_SHARED_SECRET=
TURN_SECRET=
LIVEKIT_API_KEY=hyperchat
LIVEKIT_API_SECRET=
BRIDGE_TELEGRAM_DB_PASSWORD=
BRIDGE_WHATSAPP_DB_PASSWORD=
BRIDGE_DISCORD_DB_PASSWORD=
BRIDGE_SIGNAL_DB_PASSWORD=
MAS_CLIENT_SECRET=
MAS_ADMIN_TOKEN=
MAS_ENCRYPTION_KEY=
MAS_DB_PASSWORD=
